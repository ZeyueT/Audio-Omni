{
    "model_type": "diffusion_cond",
    "sample_size": 528000,
    "sample_rate": 48000,
    "video_fps": 5,
    "audio_channels": 1,
    "model": {
        "pretransform": {
            "type": "autoencoder",
            "iterate_batch": true,
            "config": {
                "encoder": {
                    "type": "dac-vae",
                    "requires_grad": true,
                    "config": {
                        "encoder_dim": 128,
                        "encoder_rates": [2, 3, 4, 5, 8],
                        "latent_dim": 128,
                        "decoder_dim": 2048,
                        "decoder_rates": [8, 5, 4, 3, 2],
                        "n_codebooks": 9,
                        "codebook_size": 1024,
                        "codebook_dim": 8,
                        "quantizer_dropout": false,
                        "sample_rate": 48000,
                        "continuous": false,
                        "model_path": "/mnt/shanghai2cephs/zeyuetian/project/CVPR-VAE/HunyuanVideo-Foley/ckpt/vae_128d_48k.pth"
                    }
                },
                "decoder": {
                    "type": "dac-vae",
                    "config": {
                        "encoder_dim": 128,
                        "encoder_rates": [2, 3, 4, 5, 8],
                        "latent_dim": 128,
                        "decoder_dim": 2048,
                        "decoder_rates": [8, 5, 4, 3, 2],
                        "n_codebooks": 9,
                        "codebook_size": 1024,
                        "codebook_dim": 8,
                        "quantizer_dropout": false,
                        "sample_rate": 48000,
                        "continuous": false,
                        "model_path": "/mnt/shanghai2cephs/zeyuetian/project/CVPR-VAE/HunyuanVideo-Foley/ckpt/vae_128d_48k.pth"
                    }
                },   
                "latent_dim": 64,
                "downsampling_ratio": 960,
                "io_channels": 1,
                "model_path": "/mnt/shanghai2cephs/zeyuetian/project/CVPR-VAE/HunyuanVideo-Foley/ckpt/vae_128d_48k.pth"
            }
        },
        "conditioning": {
            "configs": [
                {
                    "id": "text_prompt",
                    "type": "t5",
                    "config": {
                        "t5_model_name": "t5-base",
                        "max_length": 128,
                        "mask_ratio": 0,
                        "mask_type": "input"
                    }
                }
            ],
            "cond_dim": 768
        },
        "diffusion": {
            "cross_attention_cond_ids": ["text_prompt"],
            "global_cond_ids": [],
            "type": "dit",
            "gate": false,
            "gate_type": "MAF",
            "gate_type_config": {
                "num_experts_per_modality": 64,
                "num_heads": 24,
                "num_fusion_layers": 8
            },
            "config": {
                "io_channels": 128,
                "embed_dim": 1536,
                "depth": 24,
                "num_heads": 24,
                "cond_token_dim": 768,
                "global_cond_dim": 768,
                "project_cond_tokens": false,
                "transformer_type": "continuous_transformer",
                "condition_mask_type": "cat",
                "video_fps": 5
            }
        },
        "io_channels": 128
    },
    "training": {
        "use_ema": true,
        "log_loss_info": false,
        "optimizer_configs": {
            "diffusion": {
                "optimizer": {
                    "type": "AdamW",
                    "config": {
                        "lr": 5e-5,
                        "betas": [0.9, 0.999],
                        "weight_decay": 1e-3
                    }
                },
                "scheduler": {
                    "type": "InverseLR",
                    "config": {
                        "inv_gamma": 1000000,
                        "power": 0.5,
                        "warmup": 0.99
                    }
                }
            }
        },
        "demo": {
