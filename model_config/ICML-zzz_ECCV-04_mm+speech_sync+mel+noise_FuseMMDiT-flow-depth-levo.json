{
    "model_type": "diffusion_cond",
    "sample_size": 528000,
    "sample_rate": 48000,
    "video_fps": 5,
    "audio_channels": 2,
    "model": {
        "pretransform": {
            "type": "autoencoder",
            "iterate_batch": true,
            "config": {
                "encoder": {
                    "type": "oobleck",
                    "config": {
                        "in_channels": 2,
                        "channels": 64,
                        "c_mults": [1, 2, 4, 8, 16, 32],
                        "strides": [2, 2, 4, 4, 5, 6],
                        "latent_dim": 128,
                        "use_snake": true
                    }
                },
                "decoder": {
                    "type": "oobleck",
                    "config": {
                        "out_channels": 2,
                        "channels": 64,
                        "c_mults": [1, 2, 4, 8, 16, 32],
                        "strides": [2, 2, 4, 4, 5, 6],
                        "latent_dim": 64,
                        "use_snake": true,
                        "snake_type": "vanilla",
                        "use_filter": false,
                        "final_tanh": false
                    }
                },
                "bottleneck": {
                    "type": "vae"
                },
                "latent_dim": 64,
                "downsampling_ratio": 1920,
                "io_channels": 2
            }
        },
        "conditioning": {
            "configs": [
                {
                    "id": "omni_prompt",
                    "type": "qwen_omni",
                    "config": {
                        "qwen_omni_model_name": "Qwen/Qwen2.5-Omni-3B",
                        "add_sync_feature": false,
                        "project_out": false,
                        "out_features": 2048,
                        "zip_features": true,
                        "pad_length": 2048,
                        "zip_length": 512,
                        "layer_idx": -2
                    }
                },
                {
                    "id": "sync_feature",
                    "type": "sync_feature",
                    "config": {
                        "sync_seq_dim": 240,
                        "sync_output_dim": 240,
                        "project_out": false
                    }
                },
                {
                    "id": "speech_prompt",
                    "type": "tts-f5",
                    "config": {
                        "tts_model_name": "tts-f5",
                        "vocab_file": "/mnt/shangcephfs/mm-base-vision-ascend/zeyuetian/project/AudioX-speech/data/speech/vocab.txt",
                        "seq_len": 2584,
                        "proj_seq_len": 256                        
                    }
                },
                {
                    "id": "audio_input_prompt",
                    "type": "mel_spec",
                    "config": {
                        "mel_spec_type": "mel_features",
                        "n_fft": 1024,
                        "hop_length": 256,
                        "win_length": 1024,
                        "n_mel_channels": 100,
                        "target_sample_rate": 44100,
                        "mask_ratio_start": 0.7,
                        "mask_ratio_end": 1,
                        "seq_len": 275
                    }
                }                

            ],
            "cond_dim": 768
        },
        "diffusion": {
            "cross_attention_cond_ids": ["omni_prompt", "speech_prompt"],
            "global_cond_ids": ["sync_feature", "audio_input_prompt"],
            "type": "fusemmdit",
            "gate": false,
            "diffusion_objective": "rectified_flow",
            "config": {
                "io_channels": 64,
                "embed_dim": 1536,
                "depth": 15,
                "fusion_depth": 5,
                "num_heads": 24,
                "cond_token_dim": 768,
                "global_cond_dim": 768,
                "global_dim": 515,
                "_latent_seq_len": 275,
                "mm_seq_len": 768,
                "project_cond_tokens": false,
                "transformer_type": "continuous_transformer",
                "condition_mask_type": "cat",
                "video_fps": 5
            }
        },
        "io_channels": 64
    },
    "training": {
        "use_ema": true,
        "log_loss_info": false,
        "optimizer_configs": {
            "diffusion": {
                "optimizer": {
                    "type": "AdamW",
                    "config": {
                        "lr": 5e-5,
                        "betas": [0.9, 0.999],
                        "weight_decay": 1e-3
                    }
                },
                "scheduler": {
                    "type": "InverseLR",
                    "config": {
                        "inv_gamma": 1000000,
                        "power": 0.5,
                        "warmup": 0.9995,
                        "final_lr": 4.9e-5
                    }
                }
            }
        },
        "demo": {
            "demo_every": 2000,
            "demo_steps": 250,
            "num_demos": 4,
            "demo_cond": [
                {"prompt": "Amen break 174 BPM", "seconds_start": 0, "seconds_total": 12},
                {"prompt": "A beautiful orchestral symphony, classical music", "seconds_start": 0, "seconds_total": 160},
                {"prompt": "Chill hip-hop beat, chillhop", "seconds_start": 0, "seconds_total": 190},
                {"prompt": "A pop song about love and loss", "seconds_start": 0, "seconds_total": 180}
            ],
            "demo_cfg_scales": [3, 6, 9]
        }
    }
}